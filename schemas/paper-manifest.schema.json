{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lluiseriksson.github.io/lean-rooted-tree-polymer-expansion/schemas/paper-manifest.schema.json",
  "title": "Integrated article manifest",
  "type": "object",
  "required": ["schema_version", "title", "subtitle", "author", "date", "sections"],
  "properties": {
    "schema_version": {"const": 1},
    "title": {"type": "string", "minLength": 1},
    "subtitle": {"type": "string", "minLength": 1},
    "author": {"type": "string", "minLength": 1},
    "date": {"type": "string", "minLength": 1},
    "sections": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9-]+\\.(md|bib)$"}
    }
  },
  "additionalProperties": false
}
