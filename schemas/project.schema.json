{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lluiseriksson.github.io/lean-rooted-tree-polymer-expansion/schemas/project.schema.json",
  "title": "Lean Rooted-Tree Polymer Expansion project metadata",
  "type": "object",
  "required": [
    "schema_version",
    "version",
    "release_date",
    "artifact_title",
    "site_name",
    "site_tagline",
    "repository_owner",
    "repository_slug",
    "recommended_repository_slug",
    "lean_package",
    "upstream_repository",
    "upstream_commit",
    "lean_toolchain",
    "mathlib_commit",
    "publication_model",
    "paper_entrypoint",
    "rename_status",
    "minimum_python",
    "release_profile",
    "elan_installer_commit",
    "elan_installer_blob_sha",
    "python_lock",
    "citation_schema",
    "proof_dag",
    "provenance_format"
  ],
  "properties": {
    "schema_version": {"const": 4},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "release_date": {"type": "string", "format": "date"},
    "artifact_title": {"type": "string", "minLength": 1},
    "site_name": {"type": "string", "minLength": 1},
    "site_tagline": {"type": "string", "minLength": 1},
    "repository_owner": {"type": "string", "minLength": 1},
    "repository_slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "recommended_repository_slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "previous_repository_slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "lean_package": {"type": "string", "minLength": 1},
    "upstream_repository": {"type": "string", "format": "uri"},
    "upstream_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "lean_toolchain": {"type": "string", "minLength": 1},
    "mathlib_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "publication_model": {"const": "integrated-documentation"},
    "paper_entrypoint": {"const": "docs/paper/index.md"},
    "rename_status": {"const": "adopted"},
    "minimum_python": {"const": "3.11"},
    "release_profile": {"const": "source-only-reproducible"},
    "elan_installer_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "elan_installer_blob_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "python_lock": {"const": "requirements-docs.lock"},
    "citation_schema": {"const": "schemas/citation-cff.schema.json"},
    "proof_dag": {"const": "archive/proof-dag.json"},
    "provenance_format": {"const": "in-toto-statement-v1"}
  },
  "additionalProperties": false
}
